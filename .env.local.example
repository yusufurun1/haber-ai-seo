# Haber Kaynağı API Anahtarı
# https://newsapi.org adresinden ücretsiz API key alın
NEWS_API_KEY=your_newsapi_key_here

# Site URL (SEO için gerekli - production'da gerçek domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site adı
NEXT_PUBLIC_SITE_NAME=Forex Haber

# Revalidate süresi (saniye) - haberlerin ne sıklıkla güncelleneceği
REVALIDATE_SECONDS=300
